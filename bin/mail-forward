#!/usr/bin/env bash
# mail-forward — create a forward draft
#
# Usage: mail-forward [options] <id|path>

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"

usage() {
    cat <<'EOF'
Usage: mail-forward [options] <id|path>

Create a forward draft from an existing message.

Options:
  --inline        Quote original inline (default)
  --attach        Attach original as message/rfc822 (not yet implemented)
  -h, --help      Show this help
EOF
    exit 0
}

INLINE=true
ID=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --inline)  INLINE=true; shift ;;
        --attach)  INLINE=false; shift ;;
        -h|--help) usage ;;
        *)         ID="$1"; shift ;;
    esac
done

if [[ -z "$ID" ]]; then
    echo "mail-forward: missing message ID or path" >&2
    usage
fi

# Resolve
if [[ -f "$ID" ]]; then
    FILE="$ID"
else
    FILE=$(resolve_id "$ID")
    if [[ -z "$FILE" ]]; then
        echo "mail-forward: message not found: $ID" >&2
        exit 1
    fi
fi

# Extract headers
FROM=$(extract_header "$FILE" "From")
SUBJECT=$(extract_header "$FILE" "Subject")
DATE=$(extract_header "$FILE" "Date")
TO_ORIG=$(extract_header "$FILE" "To")

# Subject prefix
SUBJECT="Fwd: ${SUBJECT#Fwd: }"
SUBJECT="${SUBJECT#FWD: }"

# My address
MY_ADDR="${MAIL_FROM:-$(config_get general.from_address)}"
[[ -z "$MY_ADDR" ]] && MY_ADDR="${USER}@$(hostname)"

# Create draft
DRAFT="$NM_MAILDIR/drafts/fwd-$(date +%Y%m%d-%H%M%S).md"
ensure_maildir

{
    echo "From: $MY_ADDR"
    echo "To: "
    echo "Cc: "
    echo "Subject: $SUBJECT"
    echo ""
    echo "---"
    echo ""

    echo "---------- Forwarded message ---------"
    echo "From: $FROM"
    echo "Date: $DATE"
    echo "Subject: $(extract_header "$FILE" "Subject")"
    echo "To: $TO_ORIG"
    echo ""

    if $INLINE; then
        extract_body "$FILE"
    else
        echo "[Original message attached]"
    fi

    echo ""

    # Signature
    local sig
    sig=$(config_get general.signature)
    [[ -n "$sig" ]] && echo "" && echo "$sig"
} > "$DRAFT"

# Open editor
open_editor "$DRAFT"

# Validate and queue
if validate_draft "$DRAFT"; then
    queue_draft "$DRAFT"
    echo "Forward queued." >&2
    exit 0
else
    echo "Draft saved to: $DRAFT (fix errors and re-run)" >&2
    exit 1
fi
