#!/usr/bin/env bash
# mail-attach — manage attachments
#
# Usage: mail-attach <list|save|open|clean> [args]

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"

usage() {
    cat <<'EOF'
Usage: mail-attach <operation> [args]

Manage the attachment directory.

Operations:
  list [id]          List attachments (all, or for specific message)
  save  ID PATH      Extract attachment from message, save to PATH
  open  ID N         Open N-th attachment from message
  clean              Remove orphaned attachments
EOF
    exit 0
}

if [[ $# -lt 1 ]]; then
    usage
fi

OP="$1"
shift

ensure_maildir
ATTACH_DIR="$NM_MAILDIR/attachments"
mkdir -p "$ATTACH_DIR"

case "$OP" in
    list)
        if [[ $# -gt 0 ]]; then
            # List attachments for specific message
            ID="$1"
            msgdir="$ATTACH_DIR/$ID"
            if [[ -d "$msgdir" ]]; then
                echo "Attachments for $ID:"
                find "$msgdir" -type f | while read -r f; do
                    size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo "?")
                    printf "  %s (%s bytes)\n" "$(basename "$f")" "$size"
                done
            else
                echo "No attachments for $ID"
            fi
        else
            echo "Attachment directories:"
            for d in "$ATTACH_DIR"/*/; do
                [[ -d "$d" ]] || continue
                count=$(find "$d" -type f 2>/dev/null | wc -l)
                printf "  %-20s %s files\n" "$(basename "$d")" "$count"
            done
        fi
        ;;

    save)
        if [[ $# -lt 2 ]]; then
            echo "mail-attach: usage: mail-attach save <id> <output-path>" >&2
            exit 1
        fi
        ID="$1"
        OUT="$2"

        FILE=$(resolve_id "$ID")
        if [[ -z "$FILE" ]]; then
            echo "mail-attach: message not found: $ID" >&2
            exit 1
        fi

        # Extract base64 encoded attachments
        # This is a simplified version — full MIME parsing needed for production
        mkdir -p "$(dirname "$OUT")"

        # Find attachment boundaries and extract
        awk '/^Content-Disposition: attachment/,/^--.*--$/' "$FILE" \
            | awk '/^$/{found=1; next} found{print}' \
            | sed '/^--/d' \
            | base64 -d 2>/dev/null > "$OUT" || {
            echo "mail-attach: could not extract attachment (may need full MIME parser)" >&2
            exit 1
        }
        echo "Saved: $OUT"
        ;;

    open)
        if [[ $# -lt 2 ]]; then
            echo "mail-attach: usage: mail-attach open <id> <n>" >&2
            exit 1
        fi
        # Simplified: find the n-th file in attachments dir
        echo "mail-attach: open not fully implemented yet" >&2
        echo "  Attachments are in: $ATTACH_DIR/$1/" >&2
        exit 1
        ;;

    clean)
        # Remove attachment dirs with no corresponding message
        count=0
        for d in "$ATTACH_DIR"/*/; do
            [[ -d "$d" ]] || continue
            id=$(basename "$d")
            if ! resolve_id "$id" &>/dev/null; then
                echo "Removing orphaned: $id"
                rm -rf "$d"
                ((count++))
            fi
        done
        echo "Removed $count orphaned attachment directories."
        ;;

    *)
        echo "mail-attach: unknown operation: $OP" >&2
        usage
        ;;
esac
