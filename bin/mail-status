#!/usr/bin/env bash
# mail-status — show mailbox status overview
#
# Usage: mail-status [--json] [--watch]

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"
source "${NM_LIBDIR}/maildir.sh"

usage() {
    cat <<'EOF'
Usage: mail-status [options]

Show mailbox status overview.

Options:
  --json      Output JSON
  --watch     Continuous refresh (every 5s)
  -h, --help  Show this help
EOF
    exit 0
}

OUTPUT_JSON=false
WATCH=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json) OUTPUT_JSON=true; shift ;;
        --watch) WATCH=true; shift ;;
        -h|--help) usage ;;
        *) shift ;;
    esac
done

ensure_maildir

get_status() {
    local in_new in_cur arch sent drafts queue_new queue_cur trash last_sync
    in_new=$(find "$NM_MAILDIR/incoming/new" -type f 2>/dev/null | wc -l)
    in_cur=$(find "$NM_MAILDIR/incoming/cur" -type f 2>/dev/null | wc -l)
    arch=$(maildir_total "$NM_MAILDIR/archive")
    sent=$(maildir_total "$NM_MAILDIR/sent")
    drafts=$(find "$NM_MAILDIR/drafts" -type f -name "*.md" 2>/dev/null | wc -l)
    queue_new=$(find "$NM_MAILDIR/queue/new" -type f 2>/dev/null | wc -l)
    queue_cur=$(find "$NM_MAILDIR/queue/cur" -type f 2>/dev/null | wc -l)
    trash=$(maildir_total "$NM_MAILDIR/trash")

    if [[ -f "$NM_STATEDIR/last-sync" ]]; then
        last_sync=$(cat "$NM_STATEDIR/last-sync")
        last_sync=$(date -d "@$last_sync" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")
    else
        last_sync="never"
    fi

    if $OUTPUT_JSON; then
        jq -n \
            --argjson in_new "$in_new" \
            --argjson in_cur "$in_cur" \
            --argjson in_total "$((in_new + in_cur))" \
            --argjson archive "$arch" \
            --argjson sent "$sent" \
            --argjson drafts "$drafts" \
            --argjson queue_new "$queue_new" \
            --argjson queue_cur "$queue_cur" \
            --argjson trash "$trash" \
            --arg last_sync "$last_sync" \
            '{
                incoming: { new: $in_new, read: $in_cur, total: $in_total },
                archive: { total: $archive },
                sent: { total: $sent },
                drafts: { pending: $drafts },
                queue: { pending: $queue_new, failed: $queue_cur },
                trash: { total: $trash },
                last_sync: $last_sync
            }'
    else
        printf "%-12s %s\n" "Incoming:" "$in_new new, $((in_new + in_cur)) total"
        printf "%-12s %s\n" "Archive:"  "$arch total"
        printf "%-12s %s\n" "Sent:"     "$sent total"
        printf "%-12s %s\n" "Drafts:"   "$drafts pending"
        printf "%-12s %s\n" "Queue:"    "$queue_new pending, $queue_cur failed"
        printf "%-12s %s\n" "Trash:"    "$trash total"
        printf "%-12s %s\n" "Last sync:" "$last_sync"
    fi
}

if $WATCH; then
    while true; do
        clear 2>/dev/null || true
        get_status
        sleep 5
    done
else
    get_status
fi
