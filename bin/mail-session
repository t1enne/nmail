#!/usr/bin/env bash
# mail-session — launch nmail tmux workspace
#
# Creates a productive terminal mail environment in tmux.
# All panes run independent tools; tmux only orchestrates.

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

MAIL_DIR="${MAIL_DIR:-$HOME/Mail}"
NM_SESSION="${NM_SESSION:-mail}"
EDITOR="${EDITOR:-nvim}"
FILE_BROWSER="${NM_FILE_BROWSER:-lf}"

# Parse args
LAYOUT="grid"
NO_SYNC=false
NO_WATCH=false

usage() {
    cat <<'EOF'
Usage: mail-session [options]

Launch nmail tmux workspace.

Options:
  --layout grid      4-pane grid layout (default)
  --layout windows   Separate tmux windows per function
  --no-sync          Don't run mail-sync on launch
  --no-watch         Don't start mail-watch
  --project NAME     Tmux session name (default: mail)
  -h, --help         Show this help
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --layout)      LAYOUT="$2"; shift 2 ;;
        --layout=*)    LAYOUT="${1#*=}"; shift ;;
        --no-sync)     NO_SYNC=true; shift ;;
        --no-watch)    NO_WATCH=true; shift ;;
        --project)     NM_SESSION="$2"; shift 2 ;;
        --project=*)   NM_SESSION="${1#*=}"; shift ;;
        -h|--help)     usage ;;
        *) shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Check tmux
# ---------------------------------------------------------------------------

if ! command -v tmux &>/dev/null; then
    echo "mail-session: tmux not found" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Attach if session exists
# ---------------------------------------------------------------------------

if tmux has-session -t "$NM_SESSION" 2>/dev/null; then
    exec tmux attach-session -t "$NM_SESSION"
fi

# ---------------------------------------------------------------------------
# Ensure Maildir exists
# ---------------------------------------------------------------------------

mkdir -p \
    "$MAIL_DIR"/{incoming,archive,drafts,sent,trash,attachments,templates,queue,logs}/{cur,new,tmp} \
    "$HOME/.local/state/nmail"

# ---------------------------------------------------------------------------
# Inital sync (unless --no-sync)
# ---------------------------------------------------------------------------

if ! $NO_SYNC && command -v mail-sync &>/dev/null; then
    mail-sync &
fi

# ---------------------------------------------------------------------------
# Start watcher (unless --no-watch)
# ---------------------------------------------------------------------------

if ! $NO_WATCH && command -v mail-watch &>/dev/null; then
    mail-watch &
fi

# ---------------------------------------------------------------------------
# Grid Layout
# ---------------------------------------------------------------------------

if [[ "$LAYOUT" == "grid" ]]; then
    tmux new-session -d -s "$NM_SESSION" -n "mail"

    # Pane 0 (top-left): compose
    tmux send-keys -t "$NM_SESSION":0.0 \
        "cd '$MAIL_DIR/drafts' && echo '=== compose (nvim) ===' && $EDITOR ." C-m

    # Pane 1 (top-right): inbox
    tmux split-window -h -t "$NM_SESSION":0.0
    tmux send-keys -t "$NM_SESSION":0.1 \
        "cd '$MAIL_DIR/incoming' && echo '=== inbox ===' && $FILE_BROWSER" C-m

    # Pane 2 (bottom-left): shell + logs + queue
    tmux split-window -v -t "$NM_SESSION":0.0
    tmux send-keys -t "$NM_SESSION":0.2 \
        "echo '=== nmail shell ==='; echo; echo '📬 Status:'; mail-status 2>/dev/null || echo '  (no mail yet)'; echo; echo '📋 Queue:'; ls '$MAIL_DIR/queue/new/' 2>/dev/null | wc -l | xargs -I{} echo '  {} pending'; echo; echo '📜 Log:'; tail -f '$MAIL_DIR/logs/mail.log' 2>/dev/null | while read line; do echo \"  \$line\"; done; exec bash" C-m

    # Pane 3 (bottom-right): search
    tmux split-window -v -t "$NM_SESSION":0.1
    tmux send-keys -t "$NM_SESSION":0.3 \
        "echo '=== search ==='; echo 'mail-search <query> --interactive'; echo; mail-status 2>/dev/null | head -3; echo; exec bash" C-m

    # Set pane sizes
    tmux select-layout -t "$NM_SESSION":0 tiled

    tmux attach-session -t "$NM_SESSION"

# ---------------------------------------------------------------------------
# Window Layout
# ---------------------------------------------------------------------------

elif [[ "$LAYOUT" == "windows" ]]; then
    tmux new-session -d -s "$NM_SESSION" -n "compose"
    tmux send-keys -t "$NM_SESSION":compose \
        "cd '$MAIL_DIR/drafts' && echo '=== compose ===' && $EDITOR ." C-m

    tmux new-window -t "$NM_SESSION" -n "inbox"
    tmux send-keys -t "$NM_SESSION":inbox \
        "cd '$MAIL_DIR/incoming' && echo '=== inbox ===' && $FILE_BROWSER" C-m

    tmux new-window -t "$NM_SESSION" -n "search"
    tmux send-keys -t "$NM_SESSION":search \
        "echo '=== search ==='; echo 'mail-search <query> --interactive'; exec bash" C-m

    tmux new-window -t "$NM_SESSION" -n "contacts"
    tmux send-keys -t "$NM_SESSION":contacts \
        "echo '=== contacts ==='; echo 'mail-contacts <query>'; exec bash" C-m

    tmux new-window -t "$NM_SESSION" -n "queue"
    tmux send-keys -t "$NM_SESSION":queue \
        "cd '$MAIL_DIR/queue/new' && echo '=== queue ===' && $FILE_BROWSER" C-m

    tmux new-window -t "$NM_SESSION" -n "logs"
    tmux send-keys -t "$NM_SESSION":logs \
        "echo '=== logs ==='; tail -f '$MAIL_DIR/logs/mail.log' 2>/dev/null || (echo 'No log yet...' && sleep 2 && tail -f '$MAIL_DIR/logs/mail.log')" C-m

    tmux new-window -t "$NM_SESSION" -n "sync"
    tmux send-keys -t "$NM_SESSION":sync \
        "echo '=== sync ==='; echo 'mail-sync'; exec bash" C-m

    tmux new-window -t "$NM_SESSION" -n "shell"
    tmux send-keys -t "$NM_SESSION":shell \
        "echo '=== nmail shell ==='; mail-status 2>/dev/null; echo; exec bash" C-m

    # Start on compose window
    tmux select-window -t "$NM_SESSION":compose

    tmux attach-session -t "$NM_SESSION"

else
    echo "mail-session: unknown layout '$LAYOUT'. Use 'grid' or 'windows'." >&2
    exit 1
fi
