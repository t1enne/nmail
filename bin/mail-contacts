#!/usr/bin/env bash
# mail-contacts — search and manage contacts
#
# Usage: mail-contacts [--update] [query]

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"

usage() {
    cat <<'EOF'
Usage: mail-contacts [options] [query]

Manage and search contacts extracted from mail.

Options:
  --update        Rebuild contact cache
  --format tsv    Tab-separated (default)
  --format json   JSON output
  -h, --help      Show this help
EOF
    exit 0
}

DO_UPDATE=false
FORMAT="tsv"
QUERY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --update)    DO_UPDATE=true; shift ;;
        --format)    FORMAT="$2"; shift 2 ;;
        --format=*)  FORMAT="${1#*=}"; shift ;;
        -h|--help)   usage ;;
        *)           QUERY="$1"; shift ;;
    esac
done

CONTACTS_FILE="$NM_STATEDIR/contacts.tsv"
mkdir -p "$NM_STATEDIR"

# Rebuild contacts cache
if $DO_UPDATE; then
    echo "Rebuilding contacts cache..." >&2

    {
        find "$NM_MAILDIR/incoming" "$NM_MAILDIR/archive" "$NM_MAILDIR/sent" \
            -type f 2>/dev/null \
            -exec grep -h '^From:\|^To:\|^Cc:' {} \; \
        | sed 's/^[^:]*: *//' \
        | tr ',' '\n' \
        | sed 's/.*<\([^>]*\)>.*/\1/' \
        | sed 's/.*\b\([a-zA-Z0-9._%+-]*@[a-zA-Z0-9.-]*\.[a-zA-Z]*\)\b.*/\1/' \
        | grep '@' \
        | sort | uniq -c | sort -rn \
        | while read -r count email; do
            # Try to find name for this email
            name=$(find "$NM_MAILDIR/incoming" "$NM_MAILDIR/archive" "$NM_MAILDIR/sent" \
                -type f 2>/dev/null \
                -exec grep -h "^From:.*$email" {} \; 2>/dev/null \
                | head -1 \
                | sed 's/^From: *//' \
                | sed 's/ <.*//' \
                | sed 's/"//g')
            [[ -z "$name" ]] && name="$email"
            printf '%s\t%s\t%s\n' "$name" "$email" "$count"
        done
    } > "$CONTACTS_FILE"

    echo "Cached $(wc -l < "$CONTACTS_FILE") contacts." >&2
fi

# Search/display
if [[ ! -f "$CONTACTS_FILE" ]]; then
    echo "No contact cache. Run: mail-contacts --update" >&2
    exit 1
fi

if [[ -n "$QUERY" ]]; then
    case "$FORMAT" in
        json)
            grep -i "$QUERY" "$CONTACTS_FILE" \
                | jq -R -s 'split("\n") | map(select(length > 0) | split("\t") | {name: .[0], email: .[1], count: .[2] | tonumber})'
            ;;
        *)
            grep -i "$QUERY" "$CONTACTS_FILE"
            ;;
    esac
else
    case "$FORMAT" in
        json)
            jq -R -s 'split("\n") | map(select(length > 0) | split("\t") | {name: .[0], email: .[1], count: .[2] | tonumber})' "$CONTACTS_FILE"
            ;;
        *)
            cat "$CONTACTS_FILE"
            ;;
    esac
fi
