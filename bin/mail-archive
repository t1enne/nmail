#!/usr/bin/env bash
# mail-archive — move message(s) to archive
#
# Usage: mail-archive <id...>
#        ... | mail-archive -

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"
source "${NM_LIBDIR}/maildir.sh"

usage() {
    cat <<'EOF'
Usage: mail-archive <id...>
       ... | mail-archive -

Move message(s) from incoming/ to archive/cur/.

Options:
  --tag TAG   Also add notmuch tag before archiving
  -h, --help  Show this help
EOF
    exit 0
}

TAG=""
IDS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --tag)   TAG="$2"; shift 2 ;;
        --tag=*) TAG="${1#*=}"; shift ;;
        -h|--help) usage ;;
        *)       IDS+=("$1"); shift ;;
    esac
done

# Read from stdin if "-" is given
if [[ ${#IDS[@]} -eq 1 && "${IDS[0]}" == "-" ]]; then
    IDS=()
    while IFS= read -r id; do
        [[ -n "$id" ]] && IDS+=("$id")
    done
fi

if [[ ${#IDS[@]} -eq 0 ]]; then
    echo "mail-archive: no IDs provided" >&2
    exit 1
fi

ensure_maildir
ARCHIVE="$NM_MAILDIR/archive"
mkdir -p "$(maildir_cur "$ARCHIVE")"

NOT_FOUND=0

for id in "${IDS[@]}"; do
    # Resolve
    if [[ -f "$id" ]]; then
        FILE="$id"
    else
        FILE=$(resolve_id "$id")
        if [[ -z "$FILE" ]]; then
            echo "mail-archive: not found: $id" >&2
            ((NOT_FOUND++))
            continue
        fi
    fi

    # Optional tag
    if [[ -n "$TAG" ]] && notmuch_available; then
        notmuch_tag "+$TAG" "$(basename "$FILE" | sed 's/:2,.*//')"
    fi

    # Move to archive
    maildir_transfer "$FILE" "$ARCHIVE"
    log_event "mail:archive" "$FILE"
done

if [[ $NOT_FOUND -gt 0 ]]; then
    exit 1
fi
exit 0
