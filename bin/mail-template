#!/usr/bin/env bash
# mail-template — manage compose templates
#
# Usage: mail-template <list|show|edit|create|delete> [name]

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"

usage() {
    cat <<'EOF'
Usage: mail-template <operation> [name]

Manage compose templates.

Operations:
  list           List available templates
  show NAME      Display template contents
  edit NAME      Edit template in $EDITOR
  create NAME    Create new template from stdin or $EDITOR
  delete NAME    Remove template
EOF
    exit 0
}

if [[ $# -lt 1 ]]; then
    usage
fi

OP="$1"
shift

ensure_maildir
TMPLDIR="$NM_MAILDIR/templates"
mkdir -p "$TMPLDIR"

# Ensure default templates exist
if [[ ! -f "$TMPLDIR/default.md" ]]; then
    cat > "$TMPLDIR/default.md" <<'EOF'
From: 
To: 
Cc: 
Subject: 

---

EOF
fi

if [[ ! -f "$TMPLDIR/reply.md" ]]; then
    cat > "$TMPLDIR/reply.md" <<'EOF'
From: 
To: 
Cc: 
Subject: 

---

On ,  wrote:

> 
EOF
fi

if [[ ! -f "$TMPLDIR/forward.md" ]]; then
    cat > "$TMPLDIR/forward.md" <<'EOF'
From: 
To: 
Cc: 
Subject: Fwd: 

---

---------- Forwarded message ---------
From: 
Date: 
Subject: 
To: 


EOF
fi

case "$OP" in
    list)
        echo "Available templates:"
        for f in "$TMPLDIR"/*.md; do
            [[ -f "$f" ]] || continue
            name=$(basename "$f" .md)
            printf "  %-20s %s\n" "$name" "$(head -1 "$f" 2>/dev/null || echo "")"
        done
        ;;

    show)
        if [[ $# -lt 1 ]]; then
            echo "mail-template: missing template name" >&2
            exit 1
        fi
        FILE="$TMPLDIR/${1}.md"
        if [[ ! -f "$FILE" ]]; then
            echo "mail-template: template not found: $1" >&2
            exit 1
        fi
        cat "$FILE"
        ;;

    edit)
        if [[ $# -lt 1 ]]; then
            echo "mail-template: missing template name" >&2
            exit 1
        fi
        FILE="$TMPLDIR/${1}.md"
        [[ ! -f "$FILE" ]] && touch "$FILE"
        open_editor "$FILE"
        ;;

    create)
        if [[ $# -lt 1 ]]; then
            echo "mail-template: missing template name" >&2
            exit 1
        fi
        FILE="$TMPLDIR/${1}.md"
        if [[ ! -t 0 ]]; then
            cat > "$FILE"
        else
            cat > "$FILE" <<'EOF'
From: 
To: 
Cc: 
Subject: 

---

EOF
            open_editor "$FILE"
        fi
        echo "Created: $FILE"
        ;;

    delete)
        if [[ $# -lt 1 ]]; then
            echo "mail-template: missing template name" >&2
            exit 1
        fi
        if [[ "$1" == "default" ]]; then
            echo "mail-template: cannot delete default template" >&2
            exit 1
        fi
        FILE="$TMPLDIR/${1}.md"
        if [[ -f "$FILE" ]]; then
            rm "$FILE"
            echo "Deleted: $1"
        else
            echo "mail-template: template not found: $1" >&2
            exit 1
        fi
        ;;

    *)
        echo "mail-template: unknown operation: $OP" >&2
        usage
        ;;
esac
