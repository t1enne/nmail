#!/usr/bin/env bash
# mail-search — search mail index
#
# Usage: mail-search [options] <query>

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"
source "${NM_LIBDIR}/notmuch.sh"

usage() {
    cat <<'EOF'
Usage: mail-search [options] <query>

Search mail index.

Options:
  --format ids        Output notmuch message IDs (default)
  --format paths      Output file paths
  --format summary    Output one-line summary per match
  --format json       Output JSON array
  --limit N           Max results (default: 100)
  --sort newest-first newest-first (default), oldest-first
  --interactive       Open fzf picker with preview
  -h, --help          Show this help
EOF
    exit 0
}

FORMAT="paths"
LIMIT=100
SORT="newest-first"
INTERACTIVE=false
QUERY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --format)      FORMAT="$2"; shift 2 ;;
        --format=*)    FORMAT="${1#*=}"; shift ;;
        --limit)       LIMIT="$2"; shift 2 ;;
        --limit=*)     LIMIT="${1#*=}"; shift ;;
        --sort)        SORT="$2"; shift 2 ;;
        --sort=*)      SORT="${1#*=}"; shift ;;
        --interactive) INTERACTIVE=true; shift ;;
        -h|--help)     usage ;;
        *)             QUERY="$1"; shift ;;
    esac
done

if [[ -z "$QUERY" ]]; then
    QUERY="*"
fi

# ---------------------------------------------------------------------------
# Interactive mode (fzf)
# ---------------------------------------------------------------------------

if $INTERACTIVE; then
    if ! command -v fzf &>/dev/null; then
        echo "mail-search: fzf not found for interactive mode" >&2
        exit 1
    fi

    # Build file list with preview data
    TMP=$(mktemp)
    notmuch_search "$QUERY" --output=files | head -n "$LIMIT" > "$TMP"

    while IFS= read -r f; do
        subj=$(extract_header "$f" "Subject")
        from=$(extract_header "$f" "From")
        date=$(extract_header "$f" "Date")
        printf '%s\t%s\t%s\t%s\n' "$date" "$from" "$subj" "$f"
    done < "$TMP" \
    | fzf --delimiter='\t' \
          --with-nth=2,3 \
          --preview='bat --language=email --color=always {4} 2>/dev/null || head -100 {4}' \
          --preview-window=right:60% \
    | cut -f4

    rm "$TMP"
    exit 0
fi

# ---------------------------------------------------------------------------
# Non-interactive: output results
# ---------------------------------------------------------------------------

RESULTS=$(notmuch_search "$QUERY" --output=files | head -n "$LIMIT")

if [[ -z "$RESULTS" ]]; then
    exit 0
fi

case "$FORMAT" in
    paths)
        echo "$RESULTS"
        ;;
    ids)
        while IFS= read -r f; do
            basename "$f" | sed 's/:2,.*//'
        done <<< "$RESULTS"
        ;;
    summary)
        while IFS= read -r f; do
            subj=$(extract_header "$f" "Subject")
            from=$(extract_header "$f" "From")
            date=$(extract_header "$f" "Date")
            id=$(basename "$f" | sed 's/:2,.*//')
            printf '%-30s  %-30s  %s  [%s]\n' "$date" "$from" "$subj" "$id"
        done <<< "$RESULTS"
        ;;
    json)
        echo "["
        first=true
        while IFS= read -r f; do
            subj=$(extract_header "$f" "Subject")
            from=$(extract_header "$f" "From")
            date=$(extract_header "$f" "Date")
            id=$(basename "$f" | sed 's/:2,.*//')
            $first || echo ","
            first=false
            printf '  {"id":"%s","from":"%s","subject":"%s","date":"%s","path":"%s"}' \
                "$id" "$from" "$subj" "$date" "$f"
        done <<< "$RESULTS"
        echo ""
        echo "]"
        ;;
    *)
        echo "$RESULTS"
        ;;
esac
