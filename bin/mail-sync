#!/usr/bin/env bash
# mail-sync — synchronize Maildir with remote IMAP
#
# Usage: mail-sync [--account NAME] [--dry-run] [--no-index]

set -euo pipefail

NM_LIBDIR="${NM_LIBDIR:-$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../src}"
source "${NM_LIBDIR}/common.sh"
source "${NM_LIBDIR}/notmuch.sh"

usage() {
    cat <<'EOF'
Usage: mail-sync [options]

Synchronize maildir with remote IMAP server(s).

Options:
  --account NAME   Sync only specific account
  --dry-run        Show what would be synced
  --full           Full sync
  --no-index       Skip notmuch re-index after sync
  -h, --help       Show this help
EOF
    exit 0
}

DRY_RUN=false
ACCOUNT=""
FULL=false
NO_INDEX=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --account)   ACCOUNT="$2"; shift 2 ;;
        --account=*) ACCOUNT="${1#*=}"; shift ;;
        --dry-run)   DRY_RUN=true; shift ;;
        --full)      FULL=true; shift ;;
        --no-index)  NO_INDEX=true; shift ;;
        -h|--help)   usage ;;
        *) shift ;;
    esac
done

ensure_maildir

SYNC_TOOL="${MAIL_SYNC_TOOL:-$(config_get sync.tool)}"
SYNC_TOOL="${SYNC_TOOL:-mbsync}"

if ! command -v "$SYNC_TOOL" &>/dev/null; then
    echo "mail-sync: sync tool not found: $SYNC_TOOL" >&2
    echo "  Install mbsync (isync) or configure sync.tool in config.toml" >&2
    exit 2
fi

# Log sync start
log_event "mail:sync-start"

if $DRY_RUN; then
    echo "[DRY-RUN] Would run: $SYNC_TOOL"
    [[ -n "$ACCOUNT" ]] && echo "[DRY-RUN]   Account: $ACCOUNT"
    exit 0
fi

# Count before sync
BEFORE_NEW=$(find "$NM_MAILDIR/incoming/new" -type f 2>/dev/null | wc -l)

# Run sync
if [[ -n "$ACCOUNT" ]]; then
    "$SYNC_TOOL" "$ACCOUNT" 2>&1 | tee -a "$NM_LOGDIR/sync.log"
else
    "$SYNC_TOOL" -a 2>&1 | tee -a "$NM_LOGDIR/sync.log"
fi

SYNC_EXIT=$?

# Count after sync
AFTER_NEW=$(find "$NM_MAILDIR/incoming/new" -type f 2>/dev/null | wc -l)
NEW_COUNT=$((AFTER_NEW - BEFORE_NEW))
[[ $NEW_COUNT -lt 0 ]] && NEW_COUNT=0

# Re-index notmuch
if ! $NO_INDEX; then
    notmuch_new
fi

# Record timestamp
date +%s > "$NM_STATEDIR/last-sync"

# Log results
if [[ $SYNC_EXIT -eq 0 ]]; then
    log_event "mail:sync-end" "$NEW_COUNT"
    if [[ $NEW_COUNT -gt 0 ]]; then
        log_event "mail:new" "$NEW_COUNT"
    fi
else
    log_event "mail:error" "sync" "sync tool exited with code $SYNC_EXIT"
fi

echo "mail-sync: $NEW_COUNT new messages" >&2
exit $SYNC_EXIT
